import os, re, math, gc
from collections import defaultdict
import numpy as np
import pandas as pd
import rasterio
from rasterio.enums import Resampling
from tqdm import tqdm

# ============================================================
# 0) Config
# ============================================================
ROOT = "/content/drive/MyDrive/anature_revised/data"

# Your GEE export grid
FINE_DEG = 0.005
ERA_DEG  = 0.10

# Downsample factor inside rasterio read.
# NOTE: if you set SPATIAL_SUBSAMPLE>1, your effective resolution becomes FINE_DEG*SPATIAL_SUBSAMPLE.
SPATIAL_SUBSAMPLE = 1

# After ERA5-guided sampling, additional random sampling usually unnecessary.
SAMPLE_FRAC = 1.0

RANDOM_SEED     = 42
CITY_LIMIT      = 100
MIN_CITY_PIXELS = 50
CITY_WHITELIST  = []

# --- Urban core by NTL quantile (brightest 90% => threshold at P10) ---
USE_NTL_CORE = True
NTL_PCT_BRIGHTEST = 99  # keep top 90% brightest
NTL_KEYS = {"NTL","VIIRS","NIGHT","NIGHTLIGHT"}
NTL_MIN_ABS = 0.0  # optional absolute minimum; keep 0 unless you want to remove true zeros

# Target selection (LST)
TARGET_PREFS = ("LST.LSTD", "LST.LST_DAY", "LST_DAY")
EXCLUDE_LST_FEATURES = True

# --- Water handling ---
# Water class code from your visualization
WATER_CODE = 17

# Drop coarse ERA5 blocks if water fraction among valid pixels exceeds this threshold
# This matches reviewer request "mask out ERA5 grid cells mostly or entirely over large bodies of water"
WATER_FRAC_THR = 0.7   # recommend 0.7 for coastal-safe; you can run sensitivity 0.5 vs 0.7
REQUIRE_LAND_PIXEL = True  # when block kept, pick sampled pixel from land-only pool if possible

# --- Sample validity: require target + core predictors finite ---
# We detect these channels by substring; adjust if your band names differ.
REQ_SUBSTRINGS = [
    "EVI", "LAI", "VPD", "SSRD", "T2M", "TD", "TP"
]
# If some are not present in common channels, we will only require those that exist.

VERBOSE = True

OUT_NPZ = (
    f"/content/ALLCITIES_train_xy_monthly_ERA5guidedREVISED_"
    f"fine{FINE_DEG}_S{SPATIAL_SUBSAMPLE}_{int(SAMPLE_FRAC*100)}pct_TOP{CITY_LIMIT}.npz"
)
OUT_CITY_STATS = f"/content/city_sampling_stats_REVISED_TOP{CITY_LIMIT}.csv"

# GDAL perf
os.environ["GDAL_NUM_THREADS"] = "ALL_CPUS"
os.environ["GDAL_CACHEMAX"]   = "2048"
ALLOW_EXT = {".tif", ".tiff"}

# ============================================================
# 1) Regex helpers
# ============================================================
DATE8  = re.compile(r"(?:^|_)(\d{8})(?:_|$)")
SUBVAR = re.compile(r"^[A-Za-z0-9]+")

# ============================================================
# 2) Utility functions
# ============================================================
def list_cities(root):
    return sorted([d for d in os.listdir(root) if os.path.isdir(os.path.join(root, d))])

def apply_city_whitelist(all_cities, whitelist):
    if not whitelist:
        return all_cities
    picked = [c for c in whitelist if c in all_cities]
    rest   = [c for c in all_cities if c not in picked]
    return picked + rest

def city_files(root, city):
    cdir = os.path.join(root, city)
    files = [
        f for f in sorted(os.listdir(cdir))
        if os.path.isfile(os.path.join(cdir, f)) and os.path.splitext(f)[1].lower() in ALLOW_EXT
    ]
    return cdir, files

def infer_var_from_filename(filename, city):
    base = re.sub(rf"^{re.escape(city)}_", "", filename, flags=re.IGNORECASE)
    return base.split("_")[0].upper()

def yyyymm_from_yyyymmdd(d8):
    return d8[:6] if (d8 and len(d8) == 8) else None

def parse_band_desc(desc, major_var):
    subvar, mkey = None, "STATIC"
    if desc:
        m_date = DATE8.search(desc)
        if m_date:
            mm = yyyymm_from_yyyymmdd(m_date.group(1))
            mkey = mm if mm else "STATIC"
        m_sv = SUBVAR.search(desc)
        if m_sv:
            subvar = m_sv.group(0).upper()
    if subvar is None:
        subvar = major_var
    return f"{major_var}.{subvar}", mkey

def get_band_descs(ds):
    descs = list(ds.descriptions) if ds.descriptions and any(ds.descriptions) else [None] * ds.count
    if len(descs) != ds.count:
        descs = (descs + [None] * ds.count)[:ds.count]
    return descs

def out_hw(h, w, s):
    return math.ceil(h / s), math.ceil(w / s)

def is_categorical_channel(chname: str) -> bool:
    # Treat LC as categorical
    up = chname.upper()
    return up.startswith("LC") or ".LC" in up

def read_downsample(ds, b, oh, ow, resampling):
    arr = ds.read(b, masked=True, out_shape=(oh, ow), resampling=resampling).astype(np.float32)
    if np.ma.isMaskedArray(arr):
        arr = arr.filled(np.nan)
    return arr

def choose_target_channel(channels):
    for pref in TARGET_PREFS:
        for ch in channels:
            if ch.upper().endswith(pref.upper()):
                return ch
    for ch in channels:
        if "LST" in ch.upper() and "LSTN" not in ch.upper():
            return ch
    for ch in channels:
        if "LST" in ch.upper():
            return ch
    return None

def find_ntl_channel(channels):
    for ch in channels:
        if any(k in ch.upper() for k in NTL_KEYS):
            return ch
    return None

def infer_water_mask_from_lc(channels, ch2i, THWC):
    """
    Infer water mask from LC.
    NOTE: user confirmed water code=17 via visualization.
    """
    lc_candidates = [c for c in channels if c.upper().startswith("LC")]
    if not lc_candidates:
        return None
    lc_ch  = lc_candidates[0]
    lc_idx = ch2i[lc_ch]
    lc_img = THWC[0, :, :, lc_idx]
    # LC might still have decimals if your export was not integer; round safely:
    lc_round = np.rint(lc_img).astype(np.float32)
    water_mask = np.isfinite(lc_round) & (lc_round == float(WATER_CODE))
    return water_mask

def era5_block_size(fine_deg, era_deg, spatial_subsample):
    eff_deg = fine_deg * spatial_subsample
    blk = int(round(era_deg / eff_deg))
    return max(1, blk)

def build_ntl_core_mask(ntl_img_2d: np.ndarray, pct_brightest: float, ntl_min_abs: float = 0.0):
    """
    Keep top pct_brightest pixels by NTL within finite domain.
    brightest 90% => threshold at P10.
    """
    m = np.isfinite(ntl_img_2d)
    if not m.any():
        return np.ones_like(ntl_img_2d, dtype=bool)
    vals = ntl_img_2d[m]
    # keep top pct => drop bottom (100-pct)
    q = np.nanpercentile(vals, 100 - pct_brightest)
    mask = m & (ntl_img_2d >= max(q, ntl_min_abs))
    return mask

def find_required_feature_indices(channels):
    """
    Find indices of required predictors by substrings.
    Only require those found.
    """
    req = []
    upchs = [c.upper() for c in channels]
    for s in REQ_SUBSTRINGS:
        su = s.upper()
        # choose first channel containing substring
        hit = None
        for i, uc in enumerate(upchs):
            if su in uc:
                hit = i
                break
        if hit is not None:
            req.append(hit)
    return sorted(set(req))

# ============================================================
# 3) ERA5-guided sampling: drop water-dominated blocks, choose 1 land pixel per block
# ============================================================
def era5_guided_one_pixel_per_block_waterdrop(valid_mask_2d, block, rng,
                                              water_mask_2d=None,
                                              water_frac_thr=0.7,
                                              require_land_pixel=True,
                                              k_per_cell=1):
    """
    For each coarse block (block x block), select K pixels (k_per_cell).
    If water_mask exists:
      - compute water fraction among valid pixels in block
      - drop block if water_frac > water_frac_thr
      - otherwise sample from land-only valid pixels (if require_land_pixel),
        fallback to any valid pixel if no land pixels exist.
    """
    H, W = valid_mask_2d.shape
    Hb = H // block
    Wb = W // block
    if Hb == 0 or Wb == 0:
        return np.array([], dtype=np.int64), {"blocks_total": 0, "blocks_used": 0, "blocks_drop_water": 0}

    # Trim to full blocks
    Ht, Wt = Hb * block, Wb * block
    valid_trim = valid_mask_2d[:Ht, :Wt]
    valid_blk = valid_trim.reshape(Hb, block, Wb, block).transpose(0, 2, 1, 3)  # (Hb,Wb,block,block)
    valid_count = valid_blk.sum(axis=(2, 3)).astype(np.int32)

    blocks_total = Hb * Wb
    usable = valid_count > 0

    blocks_drop_water = 0
    if water_mask_2d is not None:
        water_trim = water_mask_2d[:Ht, :Wt]
        water_blk = water_trim.reshape(Hb, block, Wb, block).transpose(0, 2, 1, 3)
        water_in_valid = (water_blk & valid_blk).sum(axis=(2, 3)).astype(np.int32)
        water_frac = water_in_valid / np.maximum(valid_count, 1)
        drop_water = (water_frac > water_frac_thr) & usable
        blocks_drop_water = int(drop_water.sum())
        usable = usable & (~drop_water)
        land_blk = valid_blk & (~water_blk)
    else:
        land_blk = valid_blk

    block_indices = np.argwhere(usable)

    # we will accumulate indices in Python list (K per block)
    chosen_list = []
    blocks_used = 0

    k_per_cell = int(max(1, k_per_cell))

    for bi, bj in block_indices:
        # candidate pool
        if water_mask_2d is not None and require_land_pixel:
            sub = land_blk[bi, bj]
            rr, cc = np.where(sub)
            if rr.size == 0:
                sub2 = valid_blk[bi, bj]
                rr, cc = np.where(sub2)
        else:
            sub2 = valid_blk[bi, bj]
            rr, cc = np.where(sub2)

        n = rr.size
        if n == 0:
            continue

        # choose K distinct pixels if possible
        n_pick = min(k_per_cell, n)
        pick_idx = rng.choice(n, size=n_pick, replace=False)

        for pi in pick_idx:
            r = bi * block + rr[pi]
            c = bj * block + cc[pi]
            chosen_list.append(r * W + c)

        blocks_used += 1

    stats = {
        "blocks_total": int(blocks_total),
        "blocks_used": int(blocks_used),
        "blocks_drop_water": int(blocks_drop_water),
        "k_per_cell": int(k_per_cell)
    }
    return np.array(chosen_list, dtype=np.int64), stats

# ============================================================
# 4) Process one city
# ============================================================
def process_one_city(root, city, spatial_subsample=1, sample_frac=1.0, rng=None):
    cdir, files = city_files(root, city)
    if not files:
        if VERBOSE: print(f"[{city}] ⚠️ No .tif/.tiff files; skip.")
        return None

    if VERBOSE: print(f"\n[{city}] Detected {len(files)} image files.")

    example_shape = None
    all_months, all_channels = set(), set()
    index_per_file = []  # (path, [(band, month_key, channel), ...])

    # ---- Scan structure
    for fn in tqdm(files, desc=f"[{city}] Scan structure", unit="file", disable=not VERBOSE):
        path = os.path.join(cdir, fn)
        major = infer_var_from_filename(fn, city)
        try:
            with rasterio.open(path) as ds:
                if example_shape is None:
                    example_shape = (ds.height, ds.width)
                else:
                    if (ds.height, ds.width) != example_shape:
                        if VERBOSE: print(f"[{city}] Inconsistent dims: {fn}, skip file.")
                        continue
                descs = get_band_descs(ds)
                triples = []
                for b in range(1, ds.count + 1):
                    ch, mk = parse_band_desc(descs[b - 1], major)
                    all_channels.add(ch)
                    if mk != "STATIC":
                        all_months.add(mk)
                    triples.append((b, mk, ch))
                index_per_file.append((path, triples))
        except Exception as e:
            if VERBOSE: print(f"[{city}] [Index skip] {fn}: {repr(e)}")

    if not index_per_file:
        if VERBOSE: print(f"[{city}] ⚠️ No readable files; skip.")
        return None

    months   = sorted(all_months)
    channels = sorted(all_channels)

    ch2i = {c: i for i, c in enumerate(channels)}
    m2i  = {m: i for i, m in enumerate(months)}

    H, W = example_shape
    H2, W2 = out_hw(H, W, spatial_subsample)
    T, C = len(months), len(channels)

    if VERBOSE:
        print(f"[{city}] Months={T} | Channels={C} | Downsampled size H={H2}, W={W2}")

    if T == 0 or C == 0:
        if VERBOSE: print(f"[{city}] ⚠️ No dynamic months/channels; skip.")
        return None

    rng = np.random.default_rng(RANDOM_SEED) if rng is None else rng

    # ---- Static cache
    static_cache = {}  # c_idx -> (H2,W2)
    for ch in channels:
        acc, cnt = None, 0
        for path, triples in index_per_file:
            for b, mk, c in triples:
                if c == ch and mk == "STATIC":
                    try:
                        with rasterio.open(path) as ds:
                            oh, ow = out_hw(ds.height, ds.width, spatial_subsample)
                            resamp = Resampling.nearest if is_categorical_channel(ch) else Resampling.average
                            x = read_downsample(ds, b, oh, ow, resamp)
                    except Exception as e:
                        if VERBOSE: print(f"[{city}] [STATIC skip] {os.path.basename(path)}: {repr(e)}")
                        continue
                    if acc is None:
                        acc, cnt = x, 1
                    else:
                        # merge: prefer first finite, average only for continuous
                        if is_categorical_channel(ch):
                            # categorical: fill missing only
                            m1 = np.isfinite(acc)
                            m2 = np.isfinite(x)
                            acc[~m1 & m2] = x[~m1 & m2]
                        else:
                            m1 = np.isfinite(acc); m2 = np.isfinite(x); both = m1 & m2
                            acc[~m1 & m2] = x[~m1 & m2]
                            acc[both] = (acc[both] * cnt + x[both]) / (cnt + 1)
                        cnt += 1
        if acc is not None:
            static_cache[ch2i[ch]] = acc

    # ---- SUM/CNT for dynamics
    SUM = np.zeros((T, H2, W2, C), np.float32)
    CNT = np.zeros((T, H2, W2, C), np.uint16)

    def add_sumcnt(t_idx, c_idx, arr2d):
        m = np.isfinite(arr2d)
        if m.any():
            SUM[t_idx, :arr2d.shape[0], :arr2d.shape[1], c_idx][m] += arr2d[m]
            CNT[t_idx, :arr2d.shape[0], :arr2d.shape[1], c_idx][m] += 1

    for path, triples in tqdm(index_per_file, desc=f"[{city}] Build SUM/CNT", unit="file", disable=not VERBOSE):
        with rasterio.open(path) as ds:
            oh, ow = out_hw(ds.height, ds.width, spatial_subsample)

            # bucket bands by (t_idx, c_idx)
            per_bucket = defaultdict(list)
            for b, mk, ch in triples:
                if ch not in ch2i:
                    continue
                if mk == "STATIC" or mk not in m2i:
                    continue
                per_bucket[(m2i[mk], ch2i[ch])].append(b)

            if not per_bucket:
                continue

            for (t_idx, c_idx), band_list in per_bucket.items():
                band_list = sorted(band_list)
                # choose resampling by channel type
                chname = channels[c_idx]
                resamp = Resampling.nearest if is_categorical_channel(chname) else Resampling.average
                try:
                    data = ds.read(
                        indexes=band_list, masked=True,
                        out_shape=(len(band_list), oh, ow),
                        resampling=resamp
                    ).astype(np.float32)
                    if np.ma.isMaskedArray(data):
                        data = data.filled(np.nan)

                    if is_categorical_channel(chname):
                        # categorical: take first band (or mode if you prefer)
                        arr = data[0]
                        arr = np.rint(arr).astype(np.float32)
                    else:
                        arr = np.nanmean(data, axis=0).astype(np.float32)

                    add_sumcnt(t_idx, c_idx, arr)
                except Exception as e:
                    if VERBOSE: print(f"[{city}] [Read skip] {os.path.basename(path)}: {repr(e)}")
        gc.collect()

    # ---- THWC = SUM/CNT + static broadcast
    THWC = np.full((T, H2, W2, C), np.nan, np.float32)
    valid = CNT > 0
    THWC[valid] = (SUM[valid] / CNT[valid]).astype(np.float32)
    for c_idx, arr in static_cache.items():
        THWC[:, :arr.shape[0], :arr.shape[1], c_idx] = arr

    # ---- Urban core mask: NTL quantile
    if USE_NTL_CORE:
        ntl_ch = find_ntl_channel(channels)
        if ntl_ch is not None:
            ntl_cidx = ch2i[ntl_ch]
            ntl_img  = THWC[0, :, :, ntl_cidx]
            core_mask = build_ntl_core_mask(ntl_img, pct_brightest=NTL_PCT_BRIGHTEST, ntl_min_abs=NTL_MIN_ABS)
        else:
            if VERBOSE: print(f"[{city}] ⚠️ No NTL channel found; using all pixels.")
            core_mask = np.ones((H2, W2), dtype=bool)
    else:
        core_mask = np.ones((H2, W2), dtype=bool)

    # ---- Water mask from LC (for coastal/water-dominated coarse cell dropping)
    water_mask = infer_water_mask_from_lc(channels, ch2i, THWC)

    # ---- ERA5-guided sampling (one pixel per coarse cell; drop water-dominated blocks)
    block = era5_block_size(FINE_DEG, ERA_DEG, spatial_subsample)
    pix_idx, blk_stats = era5_guided_one_pixel_per_block_waterdrop(
        valid_mask_2d=core_mask,
        block=block,
        rng=rng,
        water_mask_2d=water_mask,
        water_frac_thr=WATER_FRAC_THR,
        require_land_pixel=REQUIRE_LAND_PIXEL
    )

    n_pix = int(pix_idx.size)
    if VERBOSE:
        print(f"[{city}] ERA5-guided: block={block} -> sampled_pixels={n_pix}")
        print(f"[{city}] Blocks total={blk_stats['blocks_total']}, used={blk_stats['blocks_used']}, drop_water={blk_stats['blocks_drop_water']}")

    if n_pix < MIN_CITY_PIXELS:
        if VERBOSE: print(f"[{city}] ⚠️ Too few sampled pixels ({n_pix}<{MIN_CITY_PIXELS}); skip.")
        return None

    # ---- Target y channel
    target_ch = choose_target_channel(channels)
    if not target_ch:
        if VERBOSE: print(f"[{city}] ⚠️ LST target not found; skip.")
        return None
    y_cidx = ch2i[target_ch]

    # ---- Determine required features (city-level; will be intersected later too)
    req_idx_city = find_required_feature_indices(channels)

    # ---- Stack monthly samples using the SAME pix_idx
    X_list, y_list = [], []
    kept_per_month = []
    for t in range(T):
        slab = THWC[t]  # (H2,W2,C)
        feat = slab.reshape(-1, C)[pix_idx]
        yy   = slab[..., y_cidx].reshape(-1)[pix_idx]

        m = np.isfinite(yy)
        if req_idx_city:
            m = m & np.all(np.isfinite(feat[:, req_idx_city]), axis=1)

        if not m.any():
            kept_per_month.append(0)
            continue

        X_list.append(feat[m])
        y_list.append(yy[m])
        kept_per_month.append(int(m.sum()))

    if not X_list:
        if VERBOSE: print(f"[{city}] ⚠️ No valid samples after masking; skip.")
        return None

    X_city = np.concatenate(X_list, axis=0).astype(np.float32)
    y_city = np.concatenate(y_list, axis=0).astype(np.float32)

    if VERBOSE:
        print(f"[{city}] After monthly stack: X={X_city.shape}, y={y_city.shape}")
        print(f"[{city}] Kept samples per month (min/med/max): {np.min(kept_per_month)}/{np.median(kept_per_month)}/{np.max(kept_per_month)}")

    # ---- Optional extra random sampling
    if 0 < sample_frac < 1.0 and X_city.shape[0] > 0:
        keep = rng.choice(X_city.shape[0], size=int(round(sample_frac * X_city.shape[0])), replace=False)
        X_city, y_city = X_city[keep], y_city[keep]
        if VERBOSE:
            print(f"[{city}] After extra sampling: X={X_city.shape}, y={y_city.shape}")

    return {
        "city": city,
        "X": X_city,
        "y": y_city,
        "channels": channels,
        "target_ch": target_ch,
        "n_pix_blocks": n_pix,
        "n_samples": int(X_city.shape[0]),
        "block": int(block),
        "blocks_total": blk_stats["blocks_total"],
        "blocks_used": blk_stats["blocks_used"],
        "blocks_drop_water": blk_stats["blocks_drop_water"],
        "req_found": int(len(req_idx_city))
    }

# ============================================================
# 5) Main merge
# ============================================================
all_cities = list_cities(ROOT)
assert all_cities, f"No city subdirectories found under {ROOT}"
cities_ordered = apply_city_whitelist(all_cities, CITY_WHITELIST)

print(f"Number of cities discovered: {len(all_cities)}")
print(f"Processing first {CITY_LIMIT} cities: {cities_ordered[:CITY_LIMIT]}")

per_city = []
city_stats = []

for city in cities_ordered:
    if len(per_city) >= CITY_LIMIT:
        break
    res = process_one_city(ROOT, city, SPATIAL_SUBSAMPLE, SAMPLE_FRAC)
    if res is not None:
        per_city.append(res)
        city_stats.append({
            "city": res["city"],
            "n_pix_blocks": res["n_pix_blocks"],
            "n_samples": res["n_samples"],
            "block": res["block"],
            "target_ch": res["target_ch"],
            "blocks_total": res["blocks_total"],
            "blocks_used": res["blocks_used"],
            "blocks_drop_water": res["blocks_drop_water"],
            "req_found": res["req_found"]
        })

assert per_city, "No city reached the threshold or generated valid samples."

# ---- Identify intersection channels across cities
channel_sets = [set(x["channels"]) for x in per_city]
common_channels = sorted(set.intersection(*channel_sets))

# ---- Exclude LST* from features
if EXCLUDE_LST_FEATURES:
    common_channels = [c for c in common_channels if "LST" not in c.upper()]

print(f"Number of feature channels (intersection, excl. LST*): {len(common_channels)}")

# ---- Merge + META.CITY_ID appended
city2id = {c["city"]: i for i, c in enumerate(per_city)}
allX, ally, used_city_names = [], [], []

# Determine required indices on FINAL feature set (intersection), for later use if you want
# (We don't drop rows here because each city already applied city-level required mask.)
req_final = []
up_final = [c.upper() for c in common_channels]
for s in REQ_SUBSTRINGS:
    su = s.upper()
    for i, uc in enumerate(up_final):
        if su in uc:
            req_final.append(i)
            break
req_final = sorted(set(req_final))

for item in per_city:
    chs = item["channels"]
    col_idx = [chs.index(c) for c in common_channels] if common_channels else []
    Xc = item["X"][:, col_idx] if col_idx else item["X"][:, []]

    cid_col = np.full((Xc.shape[0], 1), city2id[item["city"]], dtype=np.float32)
    Xc = np.hstack([Xc, cid_col])

    allX.append(Xc)
    ally.append(item["y"])
    used_city_names.extend([item["city"]] * Xc.shape[0])

X = np.vstack(allX).astype(np.float32)
y = np.concatenate(ally).astype(np.float32)
channels_final = common_channels + ["META.CITY_ID"]

print(f"\n✅ Merge complete: X={X.shape}, y={y.shape}")
print(f"Used cities (n={len(sorted(set(used_city_names)))}): {sorted(set(used_city_names))[:10]} ...")
print(f"Feature channels ({len(channels_final)}): first 10 -> {channels_final[:10]}")

# ---- Save NPZ (format unchanged)
np.savez_compressed(
    OUT_NPZ,
    X=X, y=y,
    channels=np.array(channels_final, dtype=object),
    used_cities=np.array(sorted(set(used_city_names)), dtype=object),
    note=(
        f"ERA5-guided stratified sampling (REVISED): ~1 pixel per ERA5(0.1°) cell; "
        f"FINE_DEG={FINE_DEG}, ERA_DEG={ERA_DEG}, SPATIAL_SUBSAMPLE={SPATIAL_SUBSAMPLE} -> block={era5_block_size(FINE_DEG, ERA_DEG, SPATIAL_SUBSAMPLE)}; "
        f"urban core via NTL brightest {NTL_PCT_BRIGHTEST}%; "
        f"drop water-dominated coarse cells with water_frac>{WATER_FRAC_THR}; "
        f"prefer land pixel within kept coarse cells; "
        f"LC categorical resampling uses nearest; "
        f"require target + core predictors finite; "
        f"LST* excluded; META.CITY_ID appended"
    )
)

# ---- Save city sampling stats for transparency
df_stats = pd.DataFrame(city_stats).sort_values("city")
df_stats.to_csv(OUT_CITY_STATS, index=False, encoding="utf-8")

print(f"📦 Saved NPZ: {OUT_NPZ}")
print(f"📄 Saved city sampling stats: {OUT_CITY_STATS}")
print(f"🔎 Required features found (final intersection indices): {req_final} / {len(common_channels)}")
