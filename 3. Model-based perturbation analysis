def clip_feature(name, arr):
    """
    Clip perturbed feature to valid physical range.
    """
    if name == "EVI.EVI":
        return np.clip(arr, 0.0, 1.0)

    if name == "LAI.LAI":
        return np.clip(arr, 0.0, 8.0)

    return arr


def positive_deltas_by_1pct_steps(
    x_series,
    feat=None,
    hi=0.95,
    pct_step=0.01,
    max_points=201,
    evi_xmax=0.60
):
    """
    Positive perturbation Δ.

    EVI:
        Δ from 0 to 0.60, so the EVI panel x-axis is extended to 0.6.

    LAI:
        Δ from 0 to Q95 - mean_pos, following your original logic.
    """
    x = x_series.to_numpy()
    pos_mask = np.isfinite(x) & (x > 0)

    if pos_mask.sum() == 0:
        return np.array([0.0, 1e-3], dtype=np.float32)

    mean_pos = float(np.mean(x[pos_mask]))
    q_hi = float(np.quantile(x[pos_mask], hi))

    if feat == "EVI.EVI":
        max_inc = float(evi_xmax)
    else:
        max_inc = max(0.0, q_hi - mean_pos)

    if max_inc <= 1e-8:
        return np.array([0.0, 1e-4], dtype=np.float32)

    step = max(1e-6, pct_step * max(mean_pos, 1e-6))

    n_steps = int(np.floor(max_inc / step)) + 1
    n_steps = min(n_steps, max_points)

    deltas = np.linspace(0.0, max_inc, n_steps, dtype=np.float32)
    return deltas


def bootstrap_curve_ci(
    response_matrix,
    n_boot=200,
    sample_size=10000,
    ci_level=95,
    random_state=42
):
    """
    Bootstrap confidence interval for mean response curve.

    response_matrix shape:
        [n_delta, n_samples]

    Each column is one sample's perturbation-response trajectory.
    """
    n_delta, n_samples = response_matrix.shape

    if n_samples == 0:
        nan_arr = np.full(n_delta, np.nan, dtype=np.float32)
        return nan_arr, nan_arr

    sample_size = min(sample_size, n_samples)
    rng = np.random.default_rng(random_state)

    boot_means = np.empty((n_boot, n_delta), dtype=np.float32)

    for b in range(n_boot):
        idx = rng.integers(0, n_samples, size=sample_size)
        boot_means[b, :] = response_matrix[:, idx].mean(axis=1)

    alpha = (100.0 - ci_level) / 2.0

    lower = np.percentile(boot_means, alpha, axis=0).astype(np.float32)
    upper = np.percentile(boot_means, 100.0 - alpha, axis=0).astype(np.float32)

    return lower, upper


def perturb_and_response_positive_with_ci(
    model,
    X_df,
    feat,
    deltas,
    max_samples=100000,
    n_boot=200,
    bootstrap_sample_size=10000,
    ci_level=95,
    random_state=42
):
    """
    Fast perturbation-response calculation with bootstrap CI.

    Core logic:
    - Only use samples where baseline vegetation feature > 0.
    - Randomly sample at most max_samples rows.
    - Baseline = model prediction under original feature values.
    - Response = pred_after_perturbation - pred_baseline.
    - CI = bootstrap uncertainty of the mean response curve.
    """
    if feat not in X_df.columns:
        empty = np.array([], dtype=np.float32)
        return empty, empty, empty, 0

    feat_idx = X_df.columns.get_loc(feat)
    x_feat = X_df[feat].to_numpy()

    base_mask = np.isfinite(x_feat) & (x_feat > 0)

    if not base_mask.any():
        empty = np.array([], dtype=np.float32)
        return empty, empty, empty, 0

    valid_idx = np.where(base_mask)[0]

    if len(valid_idx) > max_samples:
        rng = np.random.default_rng(random_state)
        valid_idx = rng.choice(valid_idx, size=max_samples, replace=False)

    # Convert to writable contiguous numpy array
    X_base = X_df.iloc[valid_idx].to_numpy(dtype=np.float32, copy=True)
    X_base = np.ascontiguousarray(X_base, dtype=np.float32)

    X_work = X_base.copy()
    original_feat = X_base[:, feat_idx].copy()

    # Baseline prediction under original features
    y0_pred = model.predict(X_base).astype(np.float32)

    n_delta = len(deltas)
    n_used = X_base.shape[0]

    response_matrix = np.empty((n_delta, n_used), dtype=np.float32)

    for k, d in enumerate(deltas):
        X_work[:, feat_idx] = clip_feature(feat, original_feat + d).astype(np.float32)
        y_pred = model.predict(X_work).astype(np.float32)
        response_matrix[k, :] = y_pred - y0_pred

    mean_curve = response_matrix.mean(axis=1).astype(np.float32)

    lower_curve, upper_curve = bootstrap_curve_ci(
        response_matrix=response_matrix,
        n_boot=n_boot,
        sample_size=bootstrap_sample_size,
        ci_level=ci_level,
        random_state=random_state
    )

    return mean_curve, lower_curve, upper_curve, int(n_used)


def summarize_curve(deltas, response):
    """
    Summary metrics for perturbation-response curve:
    - min_cooling: strongest cooling response, i.e., most negative ΔLST
    - at_delta: Δ where strongest cooling occurs
    - sat80_delta: minimum Δ reaching 80% of strongest cooling
    - left_slope: initial slope
    - right_slope: terminal slope
    """
    out = {
        "min_cooling": np.nan,
        "at_delta": np.nan,
        "sat80_delta": np.nan,
        "left_slope": np.nan,
        "right_slope": np.nan
    }

    if response.size == 0 or deltas.size == 0:
        return out

    if np.all(~np.isfinite(response)):
        return out

    i_min = int(np.nanargmin(response))

    out["min_cooling"] = float(response[i_min])
    out["at_delta"] = float(deltas[i_min])

    target = 0.8 * response[i_min]
    sat_idx = np.where(response <= target)[0]

    if sat_idx.size:
        nearest = sat_idx[np.argmin(np.abs(deltas[sat_idx]))]
        out["sat80_delta"] = float(deltas[nearest])

    if deltas.size >= 3:
        denom_left = deltas[1] - deltas[0]
        denom_right = deltas[-1] - deltas[-2]

        if abs(denom_left) > 1e-12:
            out["left_slope"] = float((response[1] - response[0]) / denom_left)

        if abs(denom_right) > 1e-12:
            out["right_slope"] = float((response[-1] - response[-2]) / denom_right)

    return out


