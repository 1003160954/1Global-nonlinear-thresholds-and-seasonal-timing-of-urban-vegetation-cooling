        f"Sensitivity of {feat} (Positive Δ @ 1% steps of mean>0)",
        fontsize=12
    )

    ax.set_xlabel(f"{feat} positive perturbation (Δ ≥ 0)")
    ax.set_ylabel("Δ Predicted LST (°C)")

    # No background grid
    ax.grid(False)

    # EVI x-axis fixed to 0.6
    if feat == "EVI.EVI":
        ax.set_xlim(0, 1)

    ax.legend(
        loc="lower center",
        bbox_to_anchor=(0.5, 1.02),
        ncol=3,
        frameon=False
    )

    # ------------------------------------------------------------
    # Keep density histogram on the right axis
    # ------------------------------------------------------------
    ax2 = ax.twinx()

    vals = Xv[feat].to_numpy()
    vals = vals[np.isfinite(vals) & (vals > 0)]

    if vals.size:
        ax2.hist(
            vals,
            bins=30,
            alpha=0.18,
            density=True,
            color="#9ecae1"
        )

    ax2.set_ylabel("Density", color="gray")
    ax2.tick_params(axis="y", labelcolor="gray")
    ax2.grid(False)

    # ------------------------------------------------------------
    # Save statistics
    # ------------------------------------------------------------
    results[feat] = {}

    for name, resp in curves.items():
        summary = summarize_curve(deltas, resp)

        summary["n_used"] = int(n_used_dict[name])
        summary["n_delta"] = int(len(deltas))
        summary["delta_min"] = float(np.nanmin(deltas))
        summary["delta_max"] = float(np.nanmax(deltas))
        summary["n_bootstrap"] = int(N_BOOTSTRAP)
        summary["bootstrap_sample_size"] = int(
            min(BOOTSTRAP_SAMPLE_SIZE, max(n_used_dict[name], 1))
        )

        results[feat][name] = {
            "summary": summary,
            "deltas": deltas.tolist(),
            "mean_curve": resp.tolist(),
            "ci_lower": ci_lower[name].tolist(),
            "ci_upper": ci_upper[name].tolist()
        }


