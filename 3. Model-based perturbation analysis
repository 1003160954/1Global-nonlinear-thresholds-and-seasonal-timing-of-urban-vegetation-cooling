def sanitize_veg(df: pd.DataFrame) -> pd.DataFrame:
    """
    Clean vegetation variables:
    - non-finite values -> 0
    - EVI clipped to [0, 1]
    - LAI clipped to [0, 8]
    """
    if "EVI.EVI" in df.columns:
        x = df["EVI.EVI"].to_numpy(copy=True)
        x[~np.isfinite(x)] = np.nan
        x = np.nan_to_num(x, nan=0.0)
        x = np.clip(x, 0.0, 1.0)
        df["EVI.EVI"] = x.astype(np.float32)

    if "LAI.LAI" in df.columns:
        x = df["LAI.LAI"].to_numpy(copy=True)
        x[~np.isfinite(x)] = np.nan
        x = np.nan_to_num(x, nan=0.0)
        x = np.clip(x, 0.0, 8.0)
        df["LAI.LAI"] = x.astype(np.float32)

    return df


