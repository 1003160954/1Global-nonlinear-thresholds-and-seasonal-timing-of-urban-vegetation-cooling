# 3) City scanning and slab building
# ============================================================

def scan_city_files(root, city):
    cdir, files = city_files(root, city)

    if not files:
        if VERBOSE:
            print(f"[{city}] ⚠️ No tif/tiff files; skip.")
        return None

    if VERBOSE:
        print(f"\n[{city}] Detected {len(files)} raster files.")

    example_shape = None
    example_transform = None
    example_crs = None

    all_months = set()
    all_channels = set()
    index_per_file = []

    for fn in tqdm(files, desc=f"[{city}] Scan", unit="file", disable=not VERBOSE):
        path = os.path.join(cdir, fn)
        major = infer_var_from_filename(fn, city)

        try:
            with rasterio.open(path) as ds:
                if example_shape is None:
                    example_shape = (ds.height, ds.width)
                    example_transform = output_transform(ds, SPATIAL_SUBSAMPLE)
                    example_crs = ds.crs
                elif (ds.height, ds.width) != example_shape:
                    if VERBOSE:
                        print(f"[{city}] Inconsistent dimensions in {fn}; skip this file.")
                    continue

                descs = get_band_descs(ds)
                triples = []

                for b in range(1, ds.count + 1):
                    ch, mk = parse_band_desc(descs[b - 1], major)
                    all_channels.add(ch)
                    if mk != "STATIC":
                        all_months.add(mk)
                    triples.append((b, mk, ch))

                index_per_file.append((path, triples))

        except Exception as e:
            if VERBOSE:
                print(f"[{city}] [Index skip] {fn}: {repr(e)}")

    if not index_per_file:
        return None

    return {
        "index_per_file": index_per_file,
        "months_all": sorted(all_months),
        "channels_all": sorted(all_channels),
        "example_shape": example_shape,
        "example_transform": example_transform,
        "example_crs": example_crs
    }


def build_static_cache(index_per_file, channels, ch2i, H2, W2, spatial_subsample):
    static_cache = {}

    for ch in channels:
        acc, cnt = None, 0

        for path, triples in index_per_file:
            for b, mk, c in triples:
                if c != ch or mk != "STATIC":
                    continue

                try:
                    with rasterio.open(path) as ds:
                        oh, ow = out_hw(ds.height, ds.width, spatial_subsample)
                        resamp = Resampling.nearest if is_categorical_channel(ch) else Resampling.average
                        x = read_downsample(ds, b, oh, ow, resamp)
                except Exception:
                    continue

                if acc is None:
                    acc, cnt = x, 1
                else:
                    if is_categorical_channel(ch):
                        m1 = np.isfinite(acc)
                        m2 = np.isfinite(x)
                        acc[~m1 & m2] = x[~m1 & m2]
                    else:
                        m1 = np.isfinite(acc)
                        m2 = np.isfinite(x)
                        both = m1 & m2
                        acc[~m1 & m2] = x[~m1 & m2]
                        acc[both] = (acc[both] * cnt + x[both]) / (cnt + 1)
                        cnt += 1

        if acc is not None:
            temp = np.full((H2, W2), np.nan, np.float32)
            temp[:acc.shape[0], :acc.shape[1]] = acc
            static_cache[ch2i[ch]] = temp

    return static_cache


def build_month_dynamic_index(index_per_file, channels, ch2i, months):
    months_set = set(months)
    month_index = {m: [] for m in months}

    for path, triples in index_per_file:
        tmp = defaultdict(lambda: defaultdict(list))

        for b, mk, ch in triples:
            if mk == "STATIC":
                continue
            if mk not in months_set:
                continue
            if ch not in ch2i:
                continue

            c_idx = ch2i[ch]
            tmp[mk][c_idx].append(b)

        for mk, cdict in tmp.items():
            month_index[mk].append((path, dict(cdict)))

    return month_index


def build_month_slab_fast(month_index, month_key, channels, static_cache, H2, W2, spatial_subsample):
    C = len(channels)

    SUM = np.zeros((H2, W2, C), np.float32)
    CNT = np.zeros((H2, W2, C), np.uint16)

    for path, cidx_to_bands in month_index.get(month_key, []):
        try:
            with rasterio.open(path) as ds:
                oh, ow = out_hw(ds.height, ds.width, spatial_subsample)

                for c_idx, band_list in cidx_to_bands.items():
                    chname = channels[c_idx]
                    resamp = Resampling.nearest if is_categorical_channel(chname) else Resampling.average

                    data = ds.read(
                        indexes=sorted(band_list),
                        masked=True,
                        out_shape=(len(band_list), oh, ow),
                        resampling=resamp
                    ).astype(np.float32)

                    if np.ma.isMaskedArray(data):
                        data = data.filled(np.nan)

                    if is_categorical_channel(chname):
                        arr = np.rint(data[0]).astype(np.float32)
                    else:
                        with np.errstate(all="ignore"):
                            arr = np.nanmean(data, axis=0).astype(np.float32)

                    m = np.isfinite(arr)
                    if m.any():
                        SUM[:arr.shape[0], :arr.shape[1], c_idx][m] += arr[m]
                        CNT[:arr.shape[0], :arr.shape[1], c_idx][m] += 1

        except Exception as e:
            if VERBOSE:
                print(f"[month read skip] {month_key} {os.path.basename(path)}: {repr(e)}")
            continue

    slab = np.full((H2, W2, C), np.nan, np.float32)

    valid = CNT > 0
    slab[valid] = (SUM[valid] / CNT[valid]).astype(np.float32)

    for c_idx, arr in static_cache.items():
        slab[:, :, c_idx] = arr

    return slab


