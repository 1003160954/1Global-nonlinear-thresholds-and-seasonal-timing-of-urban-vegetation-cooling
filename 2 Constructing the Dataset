def process_one_city_multiyear(root, city, spatial_subsample=1, sample_frac=1.0, rng=None):
    rng = np.random.default_rng(RANDOM_SEED) if rng is None else rng

    cached = load_city_cache(city)
    if cached is not None:
        if VERBOSE:
            print(f"\n[{city}] ✅ Loaded city cache")
        return cached

    scan = scan_city_files(root, city)
    if scan is None:
        return None

    index_per_file = scan["index_per_file"]
    months_all = scan["months_all"]
    channels_all = scan["channels_all"]
    example_shape = scan["example_shape"]
    transform_out = scan["example_transform"]

    if len(months_all) == 0:
        if VERBOSE:
            print(f"[{city}] ⚠️ No dynamic months; skip.")
        return None

    months_in_range = filter_months_by_year_range(months_all, YEAR_START, YEAR_END)
    months = keep_years_with_min_months(months_in_range, MIN_MONTHS_PER_YEAR)

    if len(months) == 0:
        if VERBOSE:
            print(f"[{city}] ⚠️ No valid months in {YEAR_START}-{YEAR_END}; skip.")
        return None

    year_counts_all = summarize_years(months_all)
    year_counts_used = summarize_years(months)

    if len(year_counts_used) < MIN_CITY_YEARS:
        if VERBOSE:
            print(f"[{city}] ⚠️ Too few valid years ({len(year_counts_used)}); skip.")
        return None

    channels = channels_all
    if USE_CHANNEL_PREFILTER:
        channels = [c for c in channels_all if should_keep_channel(c)]

    if VERBOSE:
        print(f"[{city}] Months available: {len(months_all)}; months used: {len(months)}")
        print(f"[{city}] Years used: {year_counts_used}")
        print(f"[{city}] Channels kept: {len(channels_all)} -> {len(channels)}")

    ch2i = {c: i for i, c in enumerate(channels)}

    target_ch = choose_target_channel(channels)
    if not target_ch:
        if VERBOSE:
            print(f"[{city}] ⚠️ Target LST not found; skip.")
        return None

    y_cidx = ch2i[target_ch]

    if PRUNE_TRIPLES_EARLY:
        months_set = set(months)
        channels_set = set(channels)

        pruned = []
        for path, triples in index_per_file:
            tt = [
                (b, mk, ch)
                for (b, mk, ch) in triples
                if (ch in channels_set) and (mk == "STATIC" or mk in months_set)
            ]
            if tt:
                pruned.append((path, tt))

        index_per_file = pruned

    H, W = example_shape
    H2, W2 = out_hw(H, W, spatial_subsample)
    C = len(channels)

    if VERBOSE:
        print(f"[{city}] C={C}; H2xW2={H2}x{W2}; target={target_ch}")

    static_cache = build_static_cache(
        index_per_file=index_per_file,
        channels=channels,
        ch2i=ch2i,
        H2=H2,
        W2=W2,
        spatial_subsample=spatial_subsample
    )

    month_index = build_month_dynamic_index(
        index_per_file=index_per_file,
        channels=channels,
        ch2i=ch2i,
        months=months
    )

    if USE_NTL_CORE:
        ntl_ch = find_ntl_channel(channels)
        if ntl_ch is not None and ch2i[ntl_ch] in static_cache:
            ntl_img = static_cache[ch2i[ntl_ch]]
            core_mask = build_ntl_core_mask(ntl_img, NTL_PCT_BRIGHTEST, NTL_MIN_ABS)
        else:
            core_mask = np.ones((H2, W2), dtype=bool)
    else:
        core_mask = np.ones((H2, W2), dtype=bool)

    water_mask = infer_water_mask_from_lc(
        channels=channels,
        ch2i=ch2i,
        static_cache=static_cache,
        H2=H2,
        W2=W2
    )

    block = era5_block_size(FINE_DEG, ERA_DEG, spatial_subsample)

    pix_idx, blk_stats = era5_guided_one_pixel_per_block_waterdrop(
        valid_mask_2d=core_mask,
        block=block,
        rng=rng,
        water_mask_2d=water_mask,
        water_frac_thr=WATER_FRAC_THR,
        require_land_pixel=REQUIRE_LAND_PIXEL
    )

    if pix_idx.size == 0:
        if VERBOSE:
            print(f"[{city}] ⚠️ No sampled pixels; skip.")
        return None

    pix_row_all = (pix_idx // W2).astype(np.int32)
    pix_col_all = (pix_idx % W2).astype(np.int32)

    try:
        xs, ys = rasterio.transform.xy(transform_out, pix_row_all, pix_col_all, offset="center")
        pix_lon_all = np.asarray(xs, dtype=np.float32)
        pix_lat_all = np.asarray(ys, dtype=np.float32)
    except Exception:
        pix_lon_all = np.full(pix_idx.size, np.nan, dtype=np.float32)
        pix_lat_all = np.full(pix_idx.size, np.nan, dtype=np.float32)

    pix_era_row_all = (pix_row_all // block).astype(np.int32)
    pix_era_col_all = (pix_col_all // block).astype(np.int32)

    req_idx_city = find_required_feature_indices(channels)

    X_list, y_list = [], []

    meta_yyyymm, meta_year, meta_month = [], [], []
    meta_row, meta_col, meta_lon, meta_lat = [], [], [], []
    meta_era_row, meta_era_col, meta_block_id = [], [], []

    cym_counts = []

    for i_m, mkey in enumerate(
        tqdm(months, desc=f"[{city}] Build city-month samples", unit="month", disable=not VERBOSE),
        start=1
    ):
        year, month = yyyymm_to_year_month(mkey)

        slab = build_month_slab_fast(
            month_index=month_index,
            month_key=mkey,
            channels=channels,
            static_cache=static_cache,
            H2=H2,
            W2=W2,
            spatial_subsample=spatial_subsample
        )

        feat = slab.reshape(-1, C)[pix_idx]
        yy = slab[..., y_cidx].reshape(-1)[pix_idx]

        valid = np.isfinite(yy)

        if req_idx_city:
            valid = valid & np.all(np.isfinite(feat[:, req_idx_city]), axis=1)

        if not valid.any():
            cym_counts.append({
                "city": city,
                "yyyymm": mkey,
                "year": year,
                "month": month,
                "n_valid": 0,
                "n_after_cap": 0
            })
            del slab, feat, yy
            if i_m % 12 == 0:
                gc.collect()
            continue

        valid_pos = np.where(valid)[0]

        feat_valid = feat[valid_pos]
        yy_valid = yy[valid_pos]

        row_valid = pix_row_all[valid_pos]
        col_valid = pix_col_all[valid_pos]
        lon_valid = pix_lon_all[valid_pos]
        lat_valid = pix_lat_all[valid_pos]
        era_row_valid = pix_era_row_all[valid_pos]
        era_col_valid = pix_era_col_all[valid_pos]

        n_valid = feat_valid.shape[0]

        if MAX_SAMPLES_PER_CITY_MONTH is not None and n_valid > MAX_SAMPLES_PER_CITY_MONTH:
            keep = rng.choice(n_valid, size=MAX_SAMPLES_PER_CITY_MONTH, replace=False)

            feat_valid = feat_valid[keep]
            yy_valid = yy_valid[keep]

            row_valid = row_valid[keep]
            col_valid = col_valid[keep]
            lon_valid = lon_valid[keep]
            lat_valid = lat_valid[keep]
            era_row_valid = era_row_valid[keep]
            era_col_valid = era_col_valid[keep]

        n_after = feat_valid.shape[0]

        block_id_valid = np.array([
            f"{city}_er{er}_ec{ec}"
            for er, ec in zip(era_row_valid, era_col_valid)
        ], dtype=object)

        X_list.append(feat_valid.astype(np.float32))
        y_list.append(yy_valid.astype(np.float32))

        meta_yyyymm.extend([mkey] * n_after)
        meta_year.extend([year] * n_after)
        meta_month.extend([month] * n_after)

        meta_row.append(row_valid.astype(np.int32))
        meta_col.append(col_valid.astype(np.int32))
        meta_lon.append(lon_valid.astype(np.float32))
        meta_lat.append(lat_valid.astype(np.float32))
        meta_era_row.append(era_row_valid.astype(np.int32))
        meta_era_col.append(era_col_valid.astype(np.int32))
        meta_block_id.append(block_id_valid)

        cym_counts.append({
            "city": city,
            "yyyymm": mkey,
            "year": year,
            "month": month,
            "n_valid": int(n_valid),
            "n_after_cap": int(n_after)
        })

        del slab, feat, yy, feat_valid, yy_valid

        if i_m % 12 == 0:
            gc.collect()

    if not X_list:
        if VERBOSE:
            print(f"[{city}] ⚠️ No valid city-month samples; skip.")
        return None

    X_city = np.vstack(X_list).astype(np.float32)
    y_city = np.concatenate(y_list).astype(np.float32)

    meta_yyyymm = np.array(meta_yyyymm, dtype=object)
    meta_year = np.array(meta_year, dtype=np.int16)
    meta_month = np.array(meta_month, dtype=np.int8)

    meta_row = np.concatenate(meta_row).astype(np.int32)
    meta_col = np.concatenate(meta_col).astype(np.int32)
    meta_lon = np.concatenate(meta_lon).astype(np.float32)
    meta_lat = np.concatenate(meta_lat).astype(np.float32)
    meta_era_row = np.concatenate(meta_era_row).astype(np.int32)
    meta_era_col = np.concatenate(meta_era_col).astype(np.int32)
    meta_block_id = np.concatenate(meta_block_id).astype(object)

    if 0 < sample_frac < 1.0 and X_city.shape[0] > 0:
        keep = rng.choice(
            X_city.shape[0],
            size=int(round(sample_frac * X_city.shape[0])),
            replace=False
        )

        X_city = X_city[keep]
        y_city = y_city[keep]

        meta_yyyymm = meta_yyyymm[keep]
        meta_year = meta_year[keep]
        meta_month = meta_month[keep]
        meta_row = meta_row[keep]
        meta_col = meta_col[keep]
        meta_lon = meta_lon[keep]
        meta_lat = meta_lat[keep]
        meta_era_row = meta_era_row[keep]
        meta_era_col = meta_era_col[keep]
        meta_block_id = meta_block_id[keep]

    if X_city.shape[0] < MIN_CITY_SAMPLES:
        if VERBOSE:
            print(f"[{city}] ⚠️ Too few samples {X_city.shape[0]}; skip.")
        return None

    n = X_city.shape[0]

    assert y_city.shape[0] == n
    assert meta_yyyymm.shape[0] == n
    assert meta_year.shape[0] == n
    assert meta_month.shape[0] == n
    assert meta_row.shape[0] == n
    assert meta_col.shape[0] == n
    assert meta_lon.shape[0] == n
    assert meta_lat.shape[0] == n
    assert meta_era_row.shape[0] == n
    assert meta_era_col.shape[0] == n
    assert meta_block_id.shape[0] == n

    if VERBOSE:
        print(
            f"[{city}] Multi-year samples: X={X_city.shape}, y={y_city.shape}; "
            f"years={int(meta_year.min())}-{int(meta_year.max())}; "
            f"months={len(set(meta_yyyymm.tolist()))}"
        )

    city_stats = {
        "city": city,
        "n_samples": int(X_city.shape[0]),
        "n_pix_blocks": int(pix_idx.size),
        "target_ch": target_ch,
        "block": int(block),
        "blocks_total": blk_stats["blocks_total"],
        "blocks_used": blk_stats["blocks_used"],
        "blocks_drop_water": blk_stats["blocks_drop_water"],
        "n_channels_raw": int(len(channels_all)),
        "n_channels_kept": int(len(channels)),
        "n_months_available": int(len(months_all)),
        "n_months_used": int(len(months)),
        "n_years_used": int(len(set(meta_year.tolist()))),
        "year_min": int(meta_year.min()),
        "year_max": int(meta_year.max()),
        "req_found": int(len(req_idx_city)),
        "use_ntl_core": bool(USE_NTL_CORE),
        "water_frac_thr": float(WATER_FRAC_THR),
        "max_samples_per_city_month": (
            int(MAX_SAMPLES_PER_CITY_MONTH)
            if MAX_SAMPLES_PER_CITY_MONTH is not None else -1
        )
    }

    year_audit_rows = []
    all_years = sorted(set(list(year_counts_all.keys()) + list(year_counts_used.keys())))
    for yy in all_years:
        year_audit_rows.append({
            "city": city,
            "year": yy,
            "months_available": int(year_counts_all.get(yy, 0)),
            "months_used": int(year_counts_used.get(yy, 0)),
            "used": int(yy in year_counts_used)
        })

    res = {
        "city": city,
        "X": X_city,
        "y": y_city,
        "channels": channels,
        "target_ch": target_ch,

        "meta_yyyymm": meta_yyyymm,
        "meta_year": meta_year,
        "meta_month": meta_month,

        "meta_row": meta_row,
        "meta_col": meta_col,
        "meta_lon": meta_lon,
        "meta_lat": meta_lat,

        "meta_era_row": meta_era_row,
        "meta_era_col": meta_era_col,
        "meta_block_id": meta_block_id,

        "city_stats": city_stats,
        "cym_counts": cym_counts,
        "year_audit": year_audit_rows
    }

    cache_path = save_city_cache_local(res)
    if VERBOSE:
        print(f"[{city}] ✅ Local city cache saved: {cache_path}")

    return res


# ============================================================
# 6) Main processing
# ============================================================

rng = np.random.default_rng(RANDOM_SEED)

all_cities = list_cities(ROOT)
assert all_cities, f"No city subdirectories found under {ROOT}"

cities_ordered = apply_city_whitelist(all_cities, CITY_WHITELIST)

