def safe_city_filename(city):
    return re.sub(r"[^A-Za-z0-9_\-]+", "_", city)


def local_city_cache_path(city):
    return os.path.join(LOCAL_CACHE_DIR, f"{safe_city_filename(city)}_city_samples.npz")


def drive_city_cache_path(city):
    return os.path.join(DRIVE_CACHE_DIR, f"{safe_city_filename(city)}_city_samples.npz")


def save_city_cache_local(res):
    path = local_city_cache_path(res["city"])

    # Use np.savez, not compressed, for speed.
    np.savez(
        path,
        X=res["X"],
        y=res["y"],
        channels=np.array(res["channels"], dtype=object),
        meta_yyyymm=res["meta_yyyymm"],
        meta_year=res["meta_year"],
        meta_month=res["meta_month"],
        meta_row=res["meta_row"],
        meta_col=res["meta_col"],
        meta_lon=res["meta_lon"],
        meta_lat=res["meta_lat"],
        meta_era_row=res["meta_era_row"],
        meta_era_col=res["meta_era_col"],
        meta_block_id=res["meta_block_id"],
        city=np.array(res["city"], dtype=object),
        target_ch=np.array(res["target_ch"], dtype=object),
        city_stats=np.array(json.dumps(res["city_stats"], ensure_ascii=False), dtype=object),
        cym_counts=np.array(pd.DataFrame(res["cym_counts"]).to_json(orient="records", force_ascii=False), dtype=object),
        year_audit=np.array(pd.DataFrame(res["year_audit"]).to_json(orient="records", force_ascii=False), dtype=object)
    )
    return path


def copy_city_cache_to_drive(city):
    src = local_city_cache_path(city)
    if os.path.exists(src):
        os.makedirs(DRIVE_CACHE_DIR, exist_ok=True)
        dst = drive_city_cache_path(city)
        shutil.copy2(src, dst)
        return dst
    return None


def load_city_cache(city):
    # Prefer local cache; if not available, use Drive cache.
    path = local_city_cache_path(city)
    if not os.path.exists(path):
        dpath = drive_city_cache_path(city)
        if os.path.exists(dpath):
            os.makedirs(LOCAL_CACHE_DIR, exist_ok=True)
            shutil.copy2(dpath, path)

    if not os.path.exists(path):
        return None

    z = np.load(path, allow_pickle=True)
    city_name = str(z["city"].item())
    city_stats = json.loads(str(z["city_stats"].item()))
    cym_counts = pd.read_json(str(z["cym_counts"].item())).to_dict("records")
    year_audit = pd.read_json(str(z["year_audit"].item())).to_dict("records")

    return {
        "city": city_name,
        "X": z["X"].astype(np.float32),
        "y": z["y"].astype(np.float32),
        "channels": z["channels"].astype(object).tolist(),
        "target_ch": str(z["target_ch"].item()),

        "meta_yyyymm": z["meta_yyyymm"].astype(object),
        "meta_year": z["meta_year"].astype(np.int16),
        "meta_month": z["meta_month"].astype(np.int8),

        "meta_row": z["meta_row"].astype(np.int32),
        "meta_col": z["meta_col"].astype(np.int32),
        "meta_lon": z["meta_lon"].astype(np.float32),
        "meta_lat": z["meta_lat"].astype(np.float32),

        "meta_era_row": z["meta_era_row"].astype(np.int32),
        "meta_era_col": z["meta_era_col"].astype(np.int32),
        "meta_block_id": z["meta_block_id"].astype(object),

        "city_stats": city_stats,
        "cym_counts": cym_counts,
        "year_audit": year_audit
    }


