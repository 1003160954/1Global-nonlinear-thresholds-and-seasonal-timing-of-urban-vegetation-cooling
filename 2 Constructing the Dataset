    Xc = item["X"][:, col_idx]

    cid = city2id[city]

    if APPEND_CITY_ID_AS_FEATURE:
        cid_col = np.full((Xc.shape[0], 1), cid, dtype=np.float32)
        Xc = np.hstack([Xc, cid_col])

    n = Xc.shape[0]

    allX.append(Xc.astype(np.float32))
    ally.append(item["y"].astype(np.float32))

    sample_city_id.append(np.full(n, cid, dtype=np.int16))
    sample_city_name.extend([city] * n)

    sample_year.append(item["meta_year"].astype(np.int16))
    sample_month.append(item["meta_month"].astype(np.int8))
    sample_yyyymm.extend(item["meta_yyyymm"].tolist())

    sample_row.append(item["meta_row"].astype(np.int32))
