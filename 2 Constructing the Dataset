    common_years = sorted(set.intersection(*city_year_sets))
    print(f"Common years across retained cities: {common_years}")

    if not common_years:
        raise RuntimeError("No common years across all retained cities.")

    new_per_city = []

    for item in per_city:
        keep = np.isin(item["meta_year"], common_years)

        if keep.sum() < MIN_CITY_SAMPLES:
            print(f"[{item['city']}] dropped after common-year filtering: {keep.sum()} samples")
            continue

        for k in [
            "X", "y",
            "meta_yyyymm", "meta_year", "meta_month",
            "meta_row", "meta_col", "meta_lon", "meta_lat",
            "meta_era_row", "meta_era_col", "meta_block_id"
        ]:
            item[k] = item[k][keep]

        item["city_stats"]["n_samples"] = int(item["X"].shape[0])
        item["city_stats"]["n_years_used"] = int(len(set(item["meta_year"].tolist())))
        item["city_stats"]["year_min"] = int(item["meta_year"].min())
        item["city_stats"]["year_max"] = int(item["meta_year"].max())

        new_per_city.append(item)

    per_city = new_per_city
    assert per_city, "No city left after common-year filtering."


