# ============================================================
# 1) Utilities
# ============================================================

def list_cities(root):
    return sorted([
        d for d in os.listdir(root)
        if os.path.isdir(os.path.join(root, d))
    ])


def apply_city_whitelist(all_cities, whitelist):
    if not whitelist:
        return all_cities
    picked = [c for c in whitelist if c in all_cities]
    rest = [c for c in all_cities if c not in picked]
    return picked + rest


def city_files(root, city):
    cdir = os.path.join(root, city)
    files = [
        f for f in sorted(os.listdir(cdir))
        if os.path.isfile(os.path.join(cdir, f))
        and os.path.splitext(f)[1].lower() in ALLOW_EXT
    ]
    return cdir, files


def infer_var_from_filename(filename, city):
    base = re.sub(rf"^{re.escape(city)}_", "", filename, flags=re.IGNORECASE)
    return base.split("_")[0].upper()


def yyyymm_from_yyyymmdd(d8):
    return d8[:6] if (d8 and len(d8) == 8) else None


def yyyymm_to_year_month(m):
    return int(m[:4]), int(m[4:6])


def parse_band_desc(desc, major_var):
    subvar, mkey = None, "STATIC"

    if desc:
        desc = str(desc)
        m_date = DATE8.search(desc)
        if m_date:
            mm = yyyymm_from_yyyymmdd(m_date.group(1))
            mkey = mm if mm else "STATIC"

        m_sv = SUBVAR.search(desc)
        if m_sv:
            subvar = m_sv.group(0).upper()

    if subvar is None:
        subvar = major_var

    return f"{major_var}.{subvar}", mkey


def get_band_descs(ds):
    descs = list(ds.descriptions) if ds.descriptions and any(ds.descriptions) else [None] * ds.count
    if len(descs) != ds.count:
        descs = (descs + [None] * ds.count)[:ds.count]
    return descs


def out_hw(h, w, s):
    return math.ceil(h / s), math.ceil(w / s)


def output_transform(ds, spatial_subsample):
    return ds.transform * Affine.scale(spatial_subsample, spatial_subsample)


def is_categorical_channel(chname):
    up = str(chname).upper()
    return up.startswith("LC") or ".LC" in up


def read_downsample(ds, b, oh, ow, resampling):
    arr = ds.read(
        b,
        masked=True,
        out_shape=(oh, ow),
        resampling=resampling
    ).astype(np.float32)

    if np.ma.isMaskedArray(arr):
        arr = arr.filled(np.nan)

    return arr


def choose_target_channel(channels):
    for pref in TARGET_PREFS:
        for ch in channels:
            if str(ch).upper().endswith(pref.upper()):
                return ch

    for ch in channels:
        up = str(ch).upper()
        if "LST" in up and "LSTN" not in up and "NIGHT" not in up:
            return ch

    for ch in channels:
        if "LST" in str(ch).upper():
            return ch

    return None


def find_ntl_channel(channels):
    for ch in channels:
        if any(k in str(ch).upper() for k in NTL_KEYS):
            return ch
    return None


def build_ntl_core_mask(ntl_img_2d, pct_brightest, ntl_min_abs=0.0):
    m = np.isfinite(ntl_img_2d)
    if not m.any():
        return np.ones_like(ntl_img_2d, dtype=bool)
    vals = ntl_img_2d[m]
    q = np.nanpercentile(vals, 100 - pct_brightest)
    return m & (ntl_img_2d >= max(q, ntl_min_abs))


def era5_block_size(fine_deg, era_deg, spatial_subsample):
    eff_deg = fine_deg * spatial_subsample
    blk = int(round(era_deg / eff_deg))
    return max(1, blk)


def find_required_feature_indices(channels):
    req = []
    upchs = [str(c).upper() for c in channels]
    for s in REQ_SUBSTRINGS:
        su = s.upper()
        hit = None
        for i, uc in enumerate(upchs):
            if su in uc:
                hit = i
                break
        if hit is not None:
            req.append(hit)
    return sorted(set(req))


def infer_water_mask_from_lc(channels, ch2i, static_cache, H2, W2):
    lc_candidates = [c for c in channels if str(c).upper().startswith("LC") or ".LC" in str(c).upper()]
    if not lc_candidates:
        return None

    lc_ch = lc_candidates[0]
    lc_idx = ch2i[lc_ch]

    if lc_idx not in static_cache:
        return None

    lc_img = static_cache[lc_idx]
    if lc_img.shape != (H2, W2):
        temp = np.full((H2, W2), np.nan, np.float32)
        temp[:lc_img.shape[0], :lc_img.shape[1]] = lc_img
        lc_img = temp

    lc_round = np.rint(lc_img).astype(np.float32)
    return np.isfinite(lc_round) & (lc_round == float(WATER_CODE))


def should_keep_channel(chname):
    up = str(chname).upper()

    if any(h in up for h in ALWAYS_KEEP_TARGET_HINTS):
        return True

    if not USE_CHANNEL_PREFILTER:
        return True

    return any(k.upper() in up for k in KEEP_CHANNEL_SUBSTRINGS)


def filter_months_by_year_range(months_all, year_start, year_end):
    kept = []
    for m in months_all:
        if not (m and len(str(m)) >= 6 and str(m)[:4].isdigit()):
            continue
        y = int(str(m)[:4])
        if year_start <= y <= year_end:
            kept.append(m)
    return sorted(kept)


def summarize_years(months):
    d = defaultdict(int)
    for m in months:
        y, _ = yyyymm_to_year_month(m)
        d[y] += 1
    return dict(sorted(d.items()))


def keep_years_with_min_months(months, min_months):
    counts = summarize_years(months)
    good_years = {y for y, n in counts.items() if n >= min_months}
    return [m for m in months if int(m[:4]) in good_years]


def safe_copy2(src, dst_dir):
    os.makedirs(dst_dir, exist_ok=True)
    dst = os.path.join(dst_dir, os.path.basename(src))
    shutil.copy2(src, dst)
    return dst


