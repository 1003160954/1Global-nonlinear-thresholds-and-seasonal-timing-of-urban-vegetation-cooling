city2id = {item["city"]: i for i, item in enumerate(per_city)}

allX, ally = [], []

sample_city_id = []
sample_city_name = []
sample_year = []
sample_month = []
sample_yyyymm = []

sample_row = []
sample_col = []
sample_lon = []
sample_lat = []

sample_era_row = []
sample_era_col = []
